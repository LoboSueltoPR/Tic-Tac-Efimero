# Copiá este archivo a `.env` y completá los valores reales.
# Las variables VITE_* quedan expuestas en el bundle del cliente (uso personal).

# --- Claude API ---
VITE_ANTHROPIC_API_KEY=sk-ant-...

# --- Firebase (config web del proyecto) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Google Calendar (DIFERIDO) ---
# URL de la Cloud Function que sincroniza con Google Calendar usando el
# service account. Dejar vacío hasta implementar el backend.
# Las credenciales del service account (GOOGLE_SA_EMAIL, GOOGLE_SA_PRIVATE_KEY,
# GOOGLE_CALENDAR_ID) NUNCA van acá: viven en el backend, no en el cliente.
VITE_GCAL_SYNC_URL=
