# Copiá este archivo a `.env` y completá los valores reales.
# Las variables VITE_* quedan expuestas en el bundle del cliente (uso personal).

# --- IA (Groq) ---
# Key gratis en https://console.groq.com/keys
VITE_GROQ_API_KEY=gsk_...

# --- Firebase (config web del proyecto) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Google Calendar (OAuth en el navegador, sin backend) ---
# OAuth Client ID tipo "Aplicación web" de Google Cloud Console (ver README).
VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# Calendario destino ('primary' = tu calendario principal).
VITE_GOOGLE_CALENDAR_ID=primary
